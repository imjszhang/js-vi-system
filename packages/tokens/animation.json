{
  "keyframes": {
    "marquee": {
      "from": { "transform": "translateX(0%)" },
      "to": { "transform": "translateX(-100%)" }
    },
    "slideUp": {
      "from": { "opacity": "0", "transform": "translateY(20px)" },
      "to": { "opacity": "1", "transform": "translateY(0)" }
    },
    "spin": {
      "to": { "transform": "rotate(360deg)" }
    },
    "pulse": {
      "0%, 100%": { "opacity": "1" },
      "50%": { "opacity": "0.5" }
    }
  },
  "animation": {
    "marquee": {
      "value": "marquee 25s linear infinite",
      "usage": "跑马灯文字滚动"
    },
    "slide-up": {
      "value": "slideUp 0.8s ease-out forwards",
      "usage": "元素入场上滑动画"
    },
    "pulse-slow": {
      "value": "pulse 3s ease-in-out infinite",
      "usage": "缓慢脉动指示器"
    },
    "spin": {
      "value": "spin 0.8s linear infinite",
      "usage": "Loading spinner 旋转"
    }
  },
  "stagger": {
    "1": "0.1s",
    "2": "0.2s",
    "3": "0.3s",
    "4": "0.4s",
    "5": "0.5s"
  },
  "transition": {
    "fast": "all 0.1s",
    "default": "all 0.2s ease-in-out"
  }
}
