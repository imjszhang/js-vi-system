{
  "name": "wechat-cover",
  "label": "WeChat Cover",
  "fields": [
    { "key": "title", "type": "text", "required": true, "default": "文章标题\n第二行" },
    { "key": "subtitle", "type": "string", "default": "// 副标题或简短描述" },
    { "key": "tag", "type": "string", "default": "TECH" },
    { "key": "issue", "type": "string", "default": "Vol.01" }
  ],
  "sizes": ["wechat-cover", "wechat-thumb"],
  "schemes": ["daylight", "dark", "minimal"],
  "animation": {
    "supported": false
  },
  "textLayout": {
    "title": {
      "font": "900 44px Space Grotesk",
      "lineHeight": 48.4,
      "maxWidth": 756,
      "maxHeight": 200,
      "transform": "uppercase",
      "sizeOverrides": {
        "wechat-thumb": {
          "font": "900 36px Space Grotesk",
          "lineHeight": 39.6,
          "maxWidth": 404,
          "maxHeight": 300
        }
      }
    },
    "subtitle": {
      "font": "13px JetBrains Mono",
      "lineHeight": 19.5,
      "maxWidth": 756,
      "maxHeight": 60
    }
  }
}
