{
  "name": "terminal",
  "label": "Terminal",
  "fields": [
    { "key": "title", "type": "text", "required": true, "default": "SYSTEM\nINITIALIZED" },
    { "key": "subtitle", "type": "string", "default": "// Mastering AI with Eastern Philosophy" },
    { "key": "date", "type": "string", "default": "2026.03.19" },
    { "key": "location", "type": "string", "default": "CYBERSPACE" },
    { "key": "info", "type": "string", "default": "js@cyber-taoist.com" }
  ],
  "sizes": ["a4", "square", "banner", "story"],
  "schemes": ["daylight", "dark", "minimal"],
  "animation": {
    "supported": true,
    "duration": 3000,
    "defaultFps": 10,
    "description": "Typing effect with stagger entrance and cursor blink"
  },
  "textLayout": {
    "title": {
      "font": "800 56px JetBrains Mono",
      "lineHeight": 58.8,
      "maxWidth": 499,
      "maxHeight": 400,
      "transform": "uppercase",
      "sizeOverrides": {
        "square":  { "maxWidth": 544, "maxHeight": 350 },
        "banner":  { "maxWidth": 544, "maxHeight": 180 },
        "story":   { "maxWidth": 324, "maxHeight": 450 }
      }
    },
    "subtitle": {
      "font": "13px JetBrains Mono",
      "lineHeight": 23.4,
      "maxWidth": 499,
      "maxHeight": 70
    }
  }
}
